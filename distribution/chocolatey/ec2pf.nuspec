<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>ec2pf</id>
    <version>{{VERSION}}</version>
    <title>ec2pf</title>
    <authors>Kemal Abdic</authors>
    <owners>Kemal Abdic</owners>
    <projectUrl>https://github.com/KemalAbdic/ec2pf</projectUrl>
    <projectSourceUrl>https://github.com/KemalAbdic/ec2pf</projectSourceUrl>
    <bugTrackerUrl>https://github.com/KemalAbdic/ec2pf/issues</bugTrackerUrl>
    <licenseUrl>https://github.com/KemalAbdic/ec2pf/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>CLI tool for managing AWS SSM port-forwarding sessions to EC2 instances.</summary>
    <description>CLI tool for managing AWS SSM port-forwarding sessions to EC2 instances. Define your AWS settings and services in an INI config file, then start, stop, and monitor SSM sessions with automatic reconnection.</description>
    <tags>aws ssm ec2 port-forwarding cli</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
